<mxfile host="app.diagrams.net" agent="draw.io">
  <diagram id="deployment-diagram" name="Deployment Diagram">
    <mxGraphModel dx="2100" dy="1150" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1900" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ═══════════ TITLE ═══════════ -->
        <mxCell id="title" parent="1" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fontFamily=Helvetica;fontColor=#1a1a2e;" value="Smart Campus Hub — UML Deployment Diagram" vertex="1">
          <mxGeometry x="500" y="10" width="500" height="30" as="geometry"/>
        </mxCell>

        <!-- ═══════════ CLIENT DEVICE ═══════════ -->
        <mxCell id="client_device" parent="1" style="rounded=1;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;spacingTop=5;fontSize=12;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;arcSize=6;" value="«device»&#xa;Client Device" vertex="1">
          <mxGeometry x="30" y="80" width="280" height="400" as="geometry"/>
        </mxCell>
        <mxCell id="web_browser" parent="client_device" style="rounded=0;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;spacingTop=5;fontSize=11;fontStyle=1;fillColor=#FFFFFF;strokeColor=#6c8ebf;strokeWidth=1;dashed=1;dashPattern=8 8;" value="«executionEnvironment»&#xa;Web Browser" vertex="1">
          <mxGeometry x="15" y="45" width="250" height="340" as="geometry"/>
        </mxCell>
        <mxCell id="actors_note" parent="web_browser" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fontSize=10;align=left;spacingLeft=8;spacingTop=2;fillColor=#FFFFFF;strokeColor=#6c8ebf;" value="&lt;b&gt;Actors (browser-based access):&lt;/b&gt;&lt;br&gt;• Student&lt;br&gt;• Faculty&lt;br&gt;• Academic Advisor / HOD&lt;br&gt;• Administrator" vertex="1">
          <mxGeometry x="15" y="40" width="220" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="views_note" parent="web_browser" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fontSize=10;align=left;spacingLeft=8;spacingTop=2;fillColor=#FFFFFF;strokeColor=#6c8ebf;" value="&lt;b&gt;MVC Views (Boundary):&lt;/b&gt;&lt;br&gt;• LoginForm&lt;br&gt;• CourseRegistrationForm&lt;br&gt;• AttendanceForm&lt;br&gt;• GradeEntryForm&lt;br&gt;• AdminDashboard" vertex="1">
          <mxGeometry x="15" y="155" width="220" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="finance_note" parent="web_browser" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fontSize=9;align=left;spacingLeft=8;fillColor=#f5f5f5;strokeColor=#999999;dashed=1;dashPattern=8 8;fontColor=#999999;" value="• Finance Officer&lt;br&gt;  (OUT OF SCOPE — v2.0)" vertex="1">
          <mxGeometry x="15" y="280" width="220" height="45" as="geometry"/>
        </mxCell>

        <!-- ═══════════ APPLICATION SERVER ═══════════ -->
        <mxCell id="app_server" parent="1" style="rounded=1;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;spacingTop=5;fontSize=12;fontStyle=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;arcSize=4;" value="«device»&#xa;Application Server" vertex="1">
          <mxGeometry x="420" y="50" width="500" height="710" as="geometry"/>
        </mxCell>

        <!-- MVC Web Application -->
        <mxCell id="mvc_app" parent="app_server" style="rounded=0;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;spacingTop=5;fontSize=11;fontStyle=1;fillColor=#FFFFFF;strokeColor=#82b366;strokeWidth=1;dashed=1;dashPattern=8 8;" value="«executionEnvironment»&#xa;MVC Web Application (SmartCampusHub)" vertex="1">
          <mxGeometry x="15" y="45" width="470" height="370" as="geometry"/>
        </mxCell>
        <!-- Row 1 -->
        <mxCell id="auth_mod" parent="mvc_app" style="html=1;dropTarget=0;whiteSpace=wrap;fontSize=10;fontStyle=1;verticalAlign=middle;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1;" value="«component»&#xa;AuthModule&#xa;(AuthController)" vertex="1">
          <mxGeometry x="15" y="40" width="215" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="auth_icon" parent="auth_mod" style="shape=module;jettyWidth=8;jettyHeight=4;" value="" vertex="1">
          <mxGeometry x="1" width="20" height="20" relative="1" as="geometry"><mxPoint x="-27" y="7" as="offset"/></mxGeometry>
        </mxCell>
        <mxCell id="admin_mod" parent="mvc_app" style="html=1;dropTarget=0;whiteSpace=wrap;fontSize=10;fontStyle=1;verticalAlign=middle;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=1;" value="«component»&#xa;AdminModule&#xa;(AdminController)" vertex="1">
          <mxGeometry x="245" y="40" width="210" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="admin_icon" parent="admin_mod" style="shape=module;jettyWidth=8;jettyHeight=4;" value="" vertex="1">
          <mxGeometry x="1" width="20" height="20" relative="1" as="geometry"><mxPoint x="-27" y="7" as="offset"/></mxGeometry>
        </mxCell>
        <!-- Row 2 -->
        <mxCell id="academic_mod" parent="mvc_app" style="html=1;dropTarget=0;whiteSpace=wrap;fontSize=10;fontStyle=1;verticalAlign=middle;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=1;" value="«component»&#xa;AcademicModule&#xa;(EnrollmentController)" vertex="1">
          <mxGeometry x="15" y="115" width="215" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="academic_icon" parent="academic_mod" style="shape=module;jettyWidth=8;jettyHeight=4;" value="" vertex="1">
          <mxGeometry x="1" width="20" height="20" relative="1" as="geometry"><mxPoint x="-27" y="7" as="offset"/></mxGeometry>
        </mxCell>
        <mxCell id="grading_mod" parent="mvc_app" style="html=1;dropTarget=0;whiteSpace=wrap;fontSize=10;fontStyle=1;verticalAlign=middle;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=1;" value="«component»&#xa;GradingModule&#xa;(GradeController)" vertex="1">
          <mxGeometry x="245" y="115" width="210" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="grading_icon" parent="grading_mod" style="shape=module;jettyWidth=8;jettyHeight=4;" value="" vertex="1">
          <mxGeometry x="1" width="20" height="20" relative="1" as="geometry"><mxPoint x="-27" y="7" as="offset"/></mxGeometry>
        </mxCell>
        <!-- Row 3 -->
        <mxCell id="attendance_mod" parent="mvc_app" style="html=1;dropTarget=0;whiteSpace=wrap;fontSize=10;fontStyle=1;verticalAlign=middle;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=1;" value="«component»&#xa;AttendanceModule&#xa;(AttendanceController)" vertex="1">
          <mxGeometry x="15" y="190" width="215" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="attendance_icon" parent="attendance_mod" style="shape=module;jettyWidth=8;jettyHeight=4;" value="" vertex="1">
          <mxGeometry x="1" width="20" height="20" relative="1" as="geometry"><mxPoint x="-27" y="7" as="offset"/></mxGeometry>
        </mxCell>
        <mxCell id="audit_mod" parent="mvc_app" style="html=1;dropTarget=0;whiteSpace=wrap;fontSize=10;fontStyle=1;verticalAlign=middle;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=1;" value="«component»&#xa;AuditModule&#xa;(AuditController)" vertex="1">
          <mxGeometry x="245" y="190" width="210" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="audit_icon" parent="audit_mod" style="shape=module;jettyWidth=8;jettyHeight=4;" value="" vertex="1">
          <mxGeometry x="1" width="20" height="20" relative="1" as="geometry"><mxPoint x="-27" y="7" as="offset"/></mxGeometry>
        </mxCell>
        <!-- RBAC bar -->
        <mxCell id="rbac" parent="mvc_app" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fontStyle=1;verticalAlign=middle;fillColor=#E6E6E6;strokeColor=#333333;strokeWidth=1;arcSize=20;" value="RBAC / Session Manager  (bcrypt, role-based access)" vertex="1">
          <mxGeometry x="15" y="265" width="440" height="35" as="geometry"/>
        </mxCell>
        <!-- Models/Entities bar -->
        <mxCell id="models" parent="mvc_app" style="rounded=1;whiteSpace=wrap;html=1;fontSize=9;fontStyle=0;verticalAlign=middle;fillColor=#F5F5F5;strokeColor=#666666;strokeWidth=1;arcSize=20;" value="Entity Models: User, Student, Faculty, Course, Semester, CourseSection, Enrollment, Attendance, Grade, AuditLog" vertex="1">
          <mxGeometry x="15" y="312" width="440" height="40" as="geometry"/>
        </mxCell>

        <!-- Scheduler / Cron -->
        <mxCell id="scheduler" parent="app_server" style="rounded=0;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;spacingTop=5;fontSize=11;fontStyle=1;fillColor=#FFFFFF;strokeColor=#7B68A2;strokeWidth=1;dashed=1;dashPattern=8 8;" value="«executionEnvironment»&#xa;Scheduler / Cron Job Runner (System Timer)" vertex="1">
          <mxGeometry x="15" y="435" width="470" height="255" as="geometry"/>
        </mxCell>
        <mxCell id="sched_jobs" parent="scheduler" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fontSize=10;align=left;spacingLeft=10;spacingTop=4;fillColor=#e1d5e7;strokeColor=#9673a6;" value="&lt;b&gt;Scheduled Jobs (non-human actor):&lt;/b&gt;&lt;br&gt;&lt;br&gt;FR-23: Auto-lock course registration at&#xa;            configured deadline&lt;br&gt;&lt;br&gt;FR-24: Trigger low-attendance email alerts&#xa;            when threshold crossed&lt;br&gt;&lt;br&gt;FR-25: Compute end-of-semester CGPAs&#xa;            in batch after grade cutoff&lt;br&gt;&lt;br&gt;FR-26: Execute daily database backup&#xa;            at configured off-peak time" vertex="1">
          <mxGeometry x="15" y="45" width="440" height="195" as="geometry"/>
        </mxCell>

        <!-- ═══════════ DATABASE SERVER ═══════════ -->
        <mxCell id="db_server" parent="1" style="rounded=1;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;spacingTop=5;fontSize=12;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;arcSize=4;" value="«device»&#xa;Database Server" vertex="1">
          <mxGeometry x="1040" y="50" width="370" height="710" as="geometry"/>
        </mxCell>
        <mxCell id="mysql_env" parent="db_server" style="rounded=0;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;spacingTop=5;fontSize=11;fontStyle=1;fillColor=#FFFFFF;strokeColor=#d6b656;strokeWidth=1;dashed=1;dashPattern=8 8;" value="«executionEnvironment»&#xa;MySQL 8.x" vertex="1">
          <mxGeometry x="15" y="45" width="340" height="645" as="geometry"/>
        </mxCell>
        <!-- Core Tables artifact -->
        <mxCell id="tables_art" parent="mysql_env" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fontSize=10;align=left;spacingLeft=10;spacingTop=4;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;«artifact» Schema — 10 Core Tables&lt;/b&gt;&lt;br&gt;&lt;br&gt;• users&lt;br&gt;• students (FK → users)&lt;br&gt;• faculty (FK → users)&lt;br&gt;• courses&lt;br&gt;• semesters&lt;br&gt;• course_sections (FK → courses, semesters, faculty)&lt;br&gt;• enrollments (FK → students, course_sections)&lt;br&gt;  UNIQUE(student_id, section_id)&lt;br&gt;• attendance (FK → enrollments, faculty)&lt;br&gt;  UNIQUE(enrollment_id, class_date)&lt;br&gt;• grades (FK → enrollments)&lt;br&gt;• audit_log (FK → users)" vertex="1">
          <mxGeometry x="15" y="40" width="310" height="230" as="geometry"/>
        </mxCell>
        <!-- DB Triggers note -->
        <mxCell id="triggers_note" parent="mysql_env" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fontSize=10;align=left;spacingLeft=10;spacingTop=4;fillColor=#f8cecc;strokeColor=#b85450;" value="&lt;b&gt;«artifact» DB Triggers (NFR-06)&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Audit Logging:&lt;/u&gt;&lt;br&gt;• AFTER INSERT/UPDATE/DELETE on grades&#xa;  → writes to audit_log&lt;br&gt;• AFTER INSERT/UPDATE on attendance&#xa;  → writes to audit_log&lt;br&gt;&lt;br&gt;&lt;u&gt;Data Integrity:&lt;/u&gt;&lt;br&gt;• BEFORE INSERT on attendance&#xa;  → rejects if class_date &gt; CURDATE()" vertex="1">
          <mxGeometry x="15" y="285" width="310" height="185" as="geometry"/>
        </mxCell>
        <!-- Indexes note -->
        <mxCell id="indexes_note" parent="mysql_env" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fontSize=10;align=left;spacingLeft=10;spacingTop=4;fillColor=#E6E6E6;strokeColor=#666666;" value="&lt;b&gt;«artifact» Key Indexes (NFR-01)&lt;/b&gt;&lt;br&gt;&lt;br&gt;• enrollments(student_id, section_id)&lt;br&gt;• attendance(enrollment_id, class_date)&lt;br&gt;• audit_log(table_name, record_id)&lt;br&gt;• audit_log(changed_at)&lt;br&gt;• course_sections(semester_id, faculty_id)" vertex="1">
          <mxGeometry x="15" y="485" width="310" height="130" as="geometry"/>
        </mxCell>
        <!-- MySQL cylinder icon -->
        <mxCell id="db_cylinder" parent="db_server" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=8;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;fontStyle=1;strokeWidth=1;" value="MySQL" vertex="1">
          <mxGeometry x="290" y="5" width="50" height="35" as="geometry"/>
        </mxCell>

        <!-- ═══════════ EXTERNAL SERVICES ═══════════ -->
        <mxCell id="ext_services" parent="1" style="rounded=1;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;spacingTop=5;fontSize=12;fontStyle=1;fillColor=#F5F5F5;strokeColor=#999999;strokeWidth=2;arcSize=6;" value="External Services" vertex="1">
          <mxGeometry x="1530" y="80" width="260" height="320" as="geometry"/>
        </mxCell>
        <mxCell id="notif_svc" parent="ext_services" style="html=1;dropTarget=0;whiteSpace=wrap;fontSize=10;fontStyle=1;verticalAlign=middle;fillColor=#FFFFFF;strokeColor=#7B68A2;strokeWidth=1;dashed=1;dashPattern=8 8;" value="«component» [optional]&#xa;Notification / Email Service&#xa;(SMTP Relay / API)" vertex="1">
          <mxGeometry x="15" y="45" width="230" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="notif_icon" parent="notif_svc" style="shape=module;jettyWidth=8;jettyHeight=4;" value="" vertex="1">
          <mxGeometry x="1" width="20" height="20" relative="1" as="geometry"><mxPoint x="-27" y="7" as="offset"/></mxGeometry>
        </mxCell>
        <mxCell id="notif_note" parent="ext_services" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fontSize=9;align=left;spacingLeft=8;fillColor=#FFFFFF;strokeColor=#7B68A2;" value="Used by:&lt;br&gt;• FR-24: Low-attendance alerts&lt;br&gt;• FR-27: Password reset email&lt;br&gt;• Grade submission notifications" vertex="1">
          <mxGeometry x="15" y="125" width="230" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="finance_svc" parent="ext_services" style="html=1;dropTarget=0;whiteSpace=wrap;fontSize=10;fontStyle=1;verticalAlign=middle;fillColor=#f5f5f5;strokeColor=#999999;strokeWidth=1;dashed=1;dashPattern=8 8;fontColor=#999999;" value="«component»&#xa;FinanceModule&#xa;(OUT OF SCOPE — v2.0)" vertex="1">
          <mxGeometry x="15" y="215" width="230" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="finance_icon" parent="finance_svc" style="shape=module;jettyWidth=8;jettyHeight=4;strokeColor=#999999;" value="" vertex="1">
          <mxGeometry x="1" width="20" height="20" relative="1" as="geometry"><mxPoint x="-27" y="7" as="offset"/></mxGeometry>
        </mxCell>

        <!-- ═══════════ CONNECTORS ═══════════ -->

        <!-- 1. Browser → MVC Web App : HTTPS -->
        <mxCell id="edge_https" parent="1" style="endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;" edge="1" source="client_device" target="app_server">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge_https_lbl" parent="edge_https" style="edgeLabel;html=1;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#333333;fillColor=#FFFFFF;spacingLeft=4;spacingRight=4;" value="«HTTPS»" vertex="1" connectable="0">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>

        <!-- 2. MVC Web App → MySQL : TCP 3306 / JDBC -->
        <mxCell id="edge_jdbc" parent="1" style="endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=2;exitX=1;exitY=0.35;exitDx=0;exitDy=0;entryX=0;entryY=0.35;entryDx=0;entryDy=0;" edge="1" source="app_server" target="db_server">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge_jdbc_lbl" parent="edge_jdbc" style="edgeLabel;html=1;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#333333;fillColor=#FFFFFF;spacingLeft=4;spacingRight=4;" value="«TCP 3306 / JDBC»" vertex="1" connectable="0">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>

        <!-- 3. Scheduler → MySQL : TCP 3306 (backup) -->
        <mxCell id="edge_sched_db" parent="1" style="endArrow=block;endFill=1;strokeColor=#7B68A2;strokeWidth=2;dashed=1;dashPattern=8 4;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.75;entryDx=0;entryDy=0;" edge="1" source="scheduler" target="db_server">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge_sched_db_lbl" parent="edge_sched_db" style="edgeLabel;html=1;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#7B68A2;fillColor=#FFFFFF;spacingLeft=4;spacingRight=4;" value="«TCP 3306»&#xa;(backup / batch CGPA)" vertex="1" connectable="0">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>



        <!-- 5. App Server → FinanceModule : depends (OOS) -->
        <mxCell id="edge_fin" parent="1" style="endArrow=open;endSize=10;strokeColor=#999999;strokeWidth=1;dashed=1;dashPattern=8 4;fontColor=#999999;exitX=1;exitY=0.9;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="app_server" target="finance_svc">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge_fin_lbl" parent="edge_fin" style="edgeLabel;html=1;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#999999;fillColor=#FFFFFF;spacingLeft=4;spacingRight=4;" value="Future integration (v2.0)" vertex="1" connectable="0">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>

        <!-- 5b. App Server → Notification (direct route) -->
        <mxCell id="edge_app_notif" parent="1" style="endArrow=open;endSize=10;strokeColor=#7B68A2;strokeWidth=1;dashed=1;dashPattern=8 4;exitX=1;exitY=0.12;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="app_server" target="notif_svc">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge_app_notif_lbl" parent="edge_app_notif" style="edgeLabel;html=1;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#7B68A2;fillColor=#FFFFFF;spacingLeft=4;spacingRight=4;" value="«SMTP / API»&#xa;[optional]" vertex="1" connectable="0">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>

        <!-- 6. Scheduler → Notification Service : SMTP / API (FR-24 alerts) -->
        <mxCell id="edge_sched_notif" parent="1" style="endArrow=open;endSize=10;strokeColor=#7B68A2;strokeWidth=1;dashed=1;dashPattern=8 4;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=0;entryY=0.8;entryDx=0;entryDy=0;" edge="1" source="scheduler" target="notif_svc">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge_sched_notif_lbl" parent="edge_sched_notif" style="edgeLabel;html=1;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#7B68A2;fillColor=#FFFFFF;spacingLeft=4;spacingRight=4;" value="«SMTP / API»&#xa;(FR-24 alerts)" vertex="1" connectable="0">
          <mxGeometry relative="1" as="geometry"><mxPoint y="15" as="offset"/></mxGeometry>
        </mxCell>

        <!-- ═══════════ LEGEND ═══════════ -->
        <mxCell id="legend" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=18;fontSize=10;align=left;spacingLeft=10;spacingTop=4;fillColor=#FFFFFF;strokeColor=#333333;" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;&lt;hr&gt;Solid border = in-scope (v1.0)&lt;br&gt;Dashed grey = out of scope (v2.0)&lt;br&gt;Dashed purple = optional service&lt;br&gt;Module icon ⊞ = «component»&lt;br&gt;Cylinder = database&lt;br&gt;Note shape = artifact / detail" vertex="1">
          <mxGeometry x="1530" y="440" width="260" height="140" as="geometry"/>
        </mxCell>

        <!-- ═══════════ NFR SUMMARY NOTE ═══════════ -->
        <mxCell id="nfr_note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=18;fontSize=10;align=left;spacingLeft=10;spacingTop=4;fillColor=#FFFFFF;strokeColor=#333333;" value="&lt;b&gt;Key NFRs Addressed&lt;/b&gt;&lt;br&gt;&lt;hr&gt;NFR-01: Sub-2s indexed queries (indexes)&lt;br&gt;NFR-02: bcrypt password hashing (RBAC)&lt;br&gt;NFR-05: Transactional enrollment (App)&lt;br&gt;NFR-06: Audit via DB triggers (Triggers)&lt;br&gt;NFR-07: 99.5% uptime + daily backup&lt;br&gt;NFR-09: Browser-only, no plugins&lt;br&gt;NFR-10: MVC layer isolation" vertex="1">
          <mxGeometry x="1530" y="600" width="260" height="155" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
