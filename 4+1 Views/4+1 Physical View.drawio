<mxfile host="app.diagrams.net" agent="draw.io">
  <diagram id="physical-view" name="4+1 Physical View">
    <mxGraphModel dx="1800" dy="1050" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- TITLE -->
        <mxCell id="title" parent="1" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fontFamily=Helvetica;fontColor=#1a1a2e;" value="Smart Campus Hub — 4+1 Physical View (Deployment Topology)" vertex="1">
          <mxGeometry x="350" y="10" width="600" height="30" as="geometry"/>
        </mxCell>

        <!-- ═══ CLIENT TIER ═══ -->
        <mxCell id="client_node" parent="1" style="rounded=1;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;spacingTop=5;fontSize=12;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;arcSize=6;" value="«device» Client Device" vertex="1">
          <mxGeometry x="30" y="80" width="280" height="350" as="geometry"/>
        </mxCell>
        <mxCell id="browser_env" parent="client_node" style="rounded=0;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;spacingTop=5;fontSize=11;fontStyle=1;fillColor=#FFFFFF;strokeColor=#6c8ebf;strokeWidth=1;dashed=1;dashPattern=8 8;" value="«executionEnvironment»&#xa;Web Browser" vertex="1">
          <mxGeometry x="15" y="35" width="250" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="browser_note" parent="browser_env" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fontSize=9;align=left;spacingLeft=8;fillColor=#FFFFFF;strokeColor=#6c8ebf;" value="&lt;b&gt;Actors:&lt;/b&gt;&lt;br&gt;• Student&#xa;• Faculty&#xa;• Academic Advisor / HOD&#xa;• Administrator&#xa;&#xa;HTML5 / CSS / JavaScript&#xa;No plugins required (NFR-09)" vertex="1">
          <mxGeometry x="10" y="35" width="230" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="finance_actor" parent="client_node" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fontSize=9;align=left;spacingLeft=8;fillColor=#f5f5f5;strokeColor=#999999;dashed=1;dashPattern=8 8;fontColor=#999999;" value="• Finance Officer (OUT OF SCOPE — v2.0)" vertex="1">
          <mxGeometry x="15" y="250" width="250" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="client_hw" parent="client_node" style="text;html=1;fontSize=8;fontColor=#6c8ebf;align=left;" value="Desktop / Laptop / Tablet" vertex="1">
          <mxGeometry x="15" y="295" width="200" height="20" as="geometry"/>
        </mxCell>

        <!-- ═══ APPLICATION SERVER TIER ═══ -->
        <mxCell id="app_node" parent="1" style="rounded=1;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;spacingTop=5;fontSize=12;fontStyle=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;arcSize=6;" value="«device» Application Server" vertex="1">
          <mxGeometry x="430" y="80" width="310" height="350" as="geometry"/>
        </mxCell>
        <mxCell id="mvc_env" parent="app_node" style="rounded=0;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;spacingTop=5;fontSize=11;fontStyle=1;fillColor=#FFFFFF;strokeColor=#82b366;strokeWidth=1;dashed=1;dashPattern=8 8;" value="«executionEnvironment»&#xa;MVC Web Application" vertex="1">
          <mxGeometry x="15" y="35" width="280" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="mvc_modules" parent="mvc_env" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fontSize=9;align=left;spacingLeft=8;fillColor=#FFFFFF;strokeColor=#82b366;" value="&lt;b&gt;Deployed Components:&lt;/b&gt;&lt;br&gt;• AuthModule (AuthController)&#xa;• AcademicModule (EnrollmentController)&#xa;• GradingModule (GradeController)&#xa;• AttendanceModule (AttendanceController)&#xa;• AdminModule (AdminController)&#xa;• AuditModule (AuditController)&#xa;• RBAC / Session Manager" vertex="1">
          <mxGeometry x="10" y="35" width="260" height="115" as="geometry"/>
        </mxCell>
        <mxCell id="sched_env" parent="app_node" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fontStyle=1;verticalAlign=middle;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=1;dashed=1;dashPattern=8 8;" value="«executionEnvironment»&#xa;Scheduler / Cron (FR-23–FR-26)" vertex="1">
          <mxGeometry x="15" y="210" width="280" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="app_hw" parent="app_node" style="text;html=1;fontSize=8;fontColor=#82b366;align=left;" value="Linux / Windows Server • JVM / Node.js runtime" vertex="1">
          <mxGeometry x="15" y="275" width="250" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="app_nfr" parent="app_node" style="text;html=1;fontSize=8;fontColor=#82b366;align=left;" value="NFR-07: 99.5% uptime • NFR-08: 5× scalable" vertex="1">
          <mxGeometry x="15" y="300" width="250" height="20" as="geometry"/>
        </mxCell>

        <!-- ═══ DATABASE SERVER TIER ═══ -->
        <mxCell id="db_node" parent="1" style="rounded=1;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;spacingTop=5;fontSize=12;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;arcSize=6;" value="«device» Database Server" vertex="1">
          <mxGeometry x="860" y="80" width="310" height="350" as="geometry"/>
        </mxCell>
        <mxCell id="mysql_env" parent="db_node" style="rounded=0;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;spacingTop=5;fontSize=11;fontStyle=1;fillColor=#FFFFFF;strokeColor=#d6b656;strokeWidth=1;dashed=1;dashPattern=8 8;" value="«executionEnvironment»&#xa;MySQL 8.x" vertex="1">
          <mxGeometry x="15" y="35" width="280" height="240" as="geometry"/>
        </mxCell>
        <mxCell id="db_cylinder" parent="mysql_env" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=8;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;strokeWidth=1;" value="10 Core Tables" vertex="1">
          <mxGeometry x="10" y="35" width="120" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="db_triggers_n" parent="mysql_env" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fontSize=9;align=left;spacingLeft=8;fillColor=#f8cecc;strokeColor=#b85450;" value="&lt;b&gt;DB Triggers&lt;/b&gt; (NFR-06)&#xa;Audit log on grades/attendance&#xa;Future-date rejection" vertex="1">
          <mxGeometry x="10" y="90" width="260" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="db_indexes_n" parent="mysql_env" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fontSize=9;align=left;spacingLeft=8;fillColor=#E6E6E6;strokeColor=#666666;" value="&lt;b&gt;Key Indexes&lt;/b&gt; (NFR-01)&#xa;Sub-2s response at peak load" vertex="1">
          <mxGeometry x="10" y="155" width="260" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="db_hw" parent="db_node" style="text;html=1;fontSize=8;fontColor=#d6b656;align=left;" value="Dedicated DB host • TCP 3306 • Daily backups (FR-26)" vertex="1">
          <mxGeometry x="15" y="290" width="280" height="20" as="geometry"/>
        </mxCell>

        <!-- ═══ EXTERNAL SERVICES ═══ -->
        <mxCell id="ext_node" parent="1" style="rounded=1;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;spacingTop=5;fontSize=12;fontStyle=1;fillColor=#F5F5F5;strokeColor=#999999;strokeWidth=2;arcSize=6;" value="External Services" vertex="1">
          <mxGeometry x="860" y="490" width="310" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="mail_node" parent="ext_node" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fontStyle=1;verticalAlign=middle;fillColor=#FFFFFF;strokeColor=#7B68A2;strokeWidth=1;dashed=1;dashPattern=8 8;" value="«device» [optional]&#xa;Mail / SMTP Server&#xa;(FR-24 alerts, FR-27 password reset)" vertex="1">
          <mxGeometry x="15" y="35" width="280" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="finance_node" parent="ext_node" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fontStyle=1;verticalAlign=middle;fillColor=#f5f5f5;strokeColor=#999999;strokeWidth=1;dashed=1;dashPattern=8 8;fontColor=#999999;" value="«device» FinanceModule Server&#xa;(OUT OF SCOPE — v2.0)" vertex="1">
          <mxGeometry x="15" y="105" width="280" height="50" as="geometry"/>
        </mxCell>

        <!-- ═══ NETWORK CONNECTORS ═══ -->
        <!-- Client → App Server -->
        <mxCell id="net_client_app" parent="1" style="endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=2;" edge="1" source="client_node" target="app_node">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="net_client_app_l" parent="net_client_app" style="edgeLabel;html=1;fontSize=11;fontStyle=1;fontColor=#333333;fillColor=#FFFFFF;" value="«HTTPS»" vertex="1" connectable="0">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>
        <!-- App Server → DB Server -->
        <mxCell id="net_app_db" parent="1" style="endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=2;" edge="1" source="app_node" target="db_node">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="net_app_db_l" parent="net_app_db" style="edgeLabel;html=1;fontSize=11;fontStyle=1;fontColor=#333333;fillColor=#FFFFFF;" value="«TCP 3306 / JDBC»" vertex="1" connectable="0">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>
        <!-- App Server → Mail Server -->
        <mxCell id="net_app_mail" parent="1" style="endArrow=open;endSize=10;strokeColor=#7B68A2;strokeWidth=1;dashed=1;dashPattern=8 4;" edge="1" source="app_node" target="mail_node">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="net_app_mail_l" parent="net_app_mail" style="edgeLabel;html=1;fontSize=10;fontStyle=1;fontColor=#7B68A2;fillColor=#FFFFFF;" value="«SMTP / API»&#xa;[optional]" vertex="1" connectable="0">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>
        <!-- App Server → Finance (OOS) -->
        <mxCell id="net_app_fin" parent="1" style="endArrow=open;endSize=10;strokeColor=#999999;strokeWidth=1;dashed=1;dashPattern=8 4;" edge="1" source="app_node" target="finance_node">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="net_app_fin_l" parent="net_app_fin" style="edgeLabel;html=1;fontSize=10;fontStyle=1;fontColor=#999999;fillColor=#FFFFFF;" value="Future integration (v2.0)" vertex="1" connectable="0">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>

        <!-- ═══ MULTIPLICITY NOTE ═══ -->
        <mxCell id="mult_note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=18;fontSize=10;align=left;spacingLeft=10;spacingTop=4;fillColor=#FFFFFF;strokeColor=#333333;" value="&lt;b&gt;Multiplicity&lt;/b&gt;&lt;br&gt;&lt;hr&gt;Client Devices : many (1..*)&lt;br&gt;Application Server : 1 (scalable)&lt;br&gt;Database Server : 1&lt;br&gt;Mail Server : 0..1 (optional)" vertex="1">
          <mxGeometry x="30" y="490" width="260" height="100" as="geometry"/>
        </mxCell>

        <!-- ═══ LEGEND ═══ -->
        <mxCell id="legend" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=18;fontSize=10;align=left;spacingLeft=10;spacingTop=4;fillColor=#FFFFFF;strokeColor=#333333;" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;&lt;hr&gt;Solid border = in-scope node&lt;br&gt;Dashed border = optional / OOS&lt;br&gt;Solid arrow = primary data path&lt;br&gt;Dashed arrow = optional / future" vertex="1">
          <mxGeometry x="30" y="620" width="260" height="100" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
