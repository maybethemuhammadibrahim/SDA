<mxfile host="app.diagrams.net" agent="draw.io">
  <diagram id="usecase-view" name="4+1 Use Case View (+1)">
    <mxGraphModel dx="1900" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- TITLE -->
        <mxCell id="title" parent="1" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fontFamily=Helvetica;fontColor=#1a1a2e;" value="Smart Campus Hub — 4+1 Use Case View (+1) — Architecturally Significant Use Cases" vertex="1">
          <mxGeometry x="300" y="10" width="750" height="30" as="geometry"/>
        </mxCell>

        <!-- ═══ SYSTEM BOUNDARY ═══ -->
        <mxCell id="sys_boundary" parent="1" style="rounded=1;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;spacingTop=5;fontSize=13;fontStyle=1;fillColor=#FFFFFF;strokeColor=#333333;strokeWidth=2;arcSize=4;" value="«system» Smart Campus Hub" vertex="1">
          <mxGeometry x="300" y="60" width="700" height="700" as="geometry"/>
        </mxCell>

        <!-- ═══ ARCHITECTURALLY SIGNIFICANT USE CASES ═══ -->

        <!-- UC1: Register for Courses -->
        <mxCell id="uc1" parent="sys_boundary" style="ellipse;whiteSpace=wrap;html=1;fontSize=10;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=1;" value="UC1: Register&#xa;for Courses" vertex="1">
          <mxGeometry x="50" y="60" width="160" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="uc1_note" parent="sys_boundary" style="text;html=1;fontSize=8;fontColor=#d6b656;align=left;" value="Transactional (NFR-05)&#xa;Capacity + prerequisite checks" vertex="1">
          <mxGeometry x="220" y="65" width="170" height="30" as="geometry"/>
        </mxCell>

        <!-- UC2: Record Attendance -->
        <mxCell id="uc2" parent="sys_boundary" style="ellipse;whiteSpace=wrap;html=1;fontSize=10;fontStyle=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=1;" value="UC2: Record&#xa;Attendance" vertex="1">
          <mxGeometry x="50" y="160" width="160" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="uc2_note" parent="sys_boundary" style="text;html=1;fontSize=8;fontColor=#9673a6;align=left;" value="Future-date trigger rejection&#xa;Audit log on INSERT/UPDATE" vertex="1">
          <mxGeometry x="220" y="165" width="170" height="30" as="geometry"/>
        </mxCell>

        <!-- UC3: Upload / Modify Grades -->
        <mxCell id="uc3" parent="sys_boundary" style="ellipse;whiteSpace=wrap;html=1;fontSize=10;fontStyle=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=1;" value="UC3: Upload /&#xa;Modify Grades" vertex="1">
          <mxGeometry x="50" y="260" width="160" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="uc3_note" parent="sys_boundary" style="text;html=1;fontSize=8;fontColor=#9673a6;align=left;" value="Audit trigger on all DML&#xa;CHECK constraints on marks" vertex="1">
          <mxGeometry x="220" y="265" width="170" height="30" as="geometry"/>
        </mxCell>

        <!-- UC4: Manage User Accounts -->
        <mxCell id="uc4" parent="sys_boundary" style="ellipse;whiteSpace=wrap;html=1;fontSize=10;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=1;" value="UC4: Manage&#xa;User Accounts" vertex="1">
          <mxGeometry x="50" y="360" width="160" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="uc4_note" parent="sys_boundary" style="text;html=1;fontSize=8;fontColor=#6c8ebf;align=left;" value="RBAC role assignment&#xa;bcrypt password hashing" vertex="1">
          <mxGeometry x="220" y="365" width="170" height="30" as="geometry"/>
        </mxCell>

        <!-- UC5: Auto-lock Registration -->
        <mxCell id="uc5" parent="sys_boundary" style="ellipse;whiteSpace=wrap;html=1;fontSize=10;fontStyle=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=1;" value="UC5: Auto-lock&#xa;Registration (FR-23)" vertex="1">
          <mxGeometry x="420" y="60" width="170" height="70" as="geometry"/>
        </mxCell>

        <!-- UC6: Batch CGPA Compute -->
        <mxCell id="uc6" parent="sys_boundary" style="ellipse;whiteSpace=wrap;html=1;fontSize=10;fontStyle=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=1;" value="UC6: Batch CGPA&#xa;Computation (FR-25)" vertex="1">
          <mxGeometry x="420" y="160" width="170" height="70" as="geometry"/>
        </mxCell>

        <!-- UC7: Daily Backup -->
        <mxCell id="uc7" parent="sys_boundary" style="ellipse;whiteSpace=wrap;html=1;fontSize=10;fontStyle=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=1;" value="UC7: Daily DB&#xa;Backup (FR-26)" vertex="1">
          <mxGeometry x="420" y="260" width="170" height="70" as="geometry"/>
        </mxCell>

        <!-- UC8: Low-Attendance Alert -->
        <mxCell id="uc8" parent="sys_boundary" style="ellipse;whiteSpace=wrap;html=1;fontSize=10;fontStyle=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=1;" value="UC8: Low-Attendance&#xa;Alert (FR-24)" vertex="1">
          <mxGeometry x="420" y="360" width="170" height="70" as="geometry"/>
        </mxCell>

        <!-- UC-placeholder: Submit Assignments (grey) -->
        <mxCell id="uc_assign" parent="sys_boundary" style="ellipse;whiteSpace=wrap;html=1;fontSize=9;fontStyle=1;fillColor=#f5f5f5;strokeColor=#999999;strokeWidth=1;dashed=1;dashPattern=8 8;fontColor=#999999;" value="Submit Assignments&#xa;(LMS — placeholder)" vertex="1">
          <mxGeometry x="50" y="470" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- UC-placeholder: Exam Seating (grey) -->
        <mxCell id="uc_exam" parent="sys_boundary" style="ellipse;whiteSpace=wrap;html=1;fontSize=9;fontStyle=1;fillColor=#f5f5f5;strokeColor=#999999;strokeWidth=1;dashed=1;dashPattern=8 8;fontColor=#999999;" value="View Exam Seating&#xa;(no backing table)" vertex="1">
          <mxGeometry x="50" y="550" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- UC-placeholder: Fee Vouchers (grey) -->
        <mxCell id="uc_fee" parent="sys_boundary" style="ellipse;whiteSpace=wrap;html=1;fontSize=9;fontStyle=1;fillColor=#f5f5f5;strokeColor=#999999;strokeWidth=1;dashed=1;dashPattern=8 8;fontColor=#999999;" value="Download Fee Vouchers&#xa;(Finance — v2.0)" vertex="1">
          <mxGeometry x="50" y="630" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- UC: View Transcript -->
        <mxCell id="uc_transcript" parent="sys_boundary" style="ellipse;whiteSpace=wrap;html=1;fontSize=10;fontStyle=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1;" value="UC9: View Transcript&#xa;/ CGPA (FR-02)" vertex="1">
          <mxGeometry x="420" y="470" width="170" height="70" as="geometry"/>
        </mxCell>

        <!-- UC: Institutional Reports -->
        <mxCell id="uc_reports" parent="sys_boundary" style="ellipse;whiteSpace=wrap;html=1;fontSize=10;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=1;" value="UC10: Generate&#xa;Institutional Reports" vertex="1">
          <mxGeometry x="420" y="560" width="170" height="70" as="geometry"/>
        </mxCell>

        <!-- ═══ ACTORS ═══ -->
        <!-- Student -->
        <mxCell id="actor_student" parent="1" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;fontSize=10;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="Student" vertex="1">
          <mxGeometry x="120" y="140" width="30" height="55" as="geometry"/>
        </mxCell>
        <!-- Faculty -->
        <mxCell id="actor_faculty" parent="1" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;fontSize=10;fontStyle=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="Faculty" vertex="1">
          <mxGeometry x="120" y="290" width="30" height="55" as="geometry"/>
        </mxCell>
        <!-- Advisor / HOD -->
        <mxCell id="actor_advisor" parent="1" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;fontSize=10;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="Advisor / HOD" vertex="1">
          <mxGeometry x="120" y="420" width="30" height="55" as="geometry"/>
        </mxCell>
        <!-- Administrator -->
        <mxCell id="actor_admin" parent="1" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;fontSize=10;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="Administrator" vertex="1">
          <mxGeometry x="120" y="540" width="30" height="55" as="geometry"/>
        </mxCell>
        <!-- System / Timer -->
        <mxCell id="actor_system" parent="1" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;fontSize=10;fontStyle=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="System / Timer" vertex="1">
          <mxGeometry x="1120" y="200" width="30" height="55" as="geometry"/>
        </mxCell>
        <!-- Finance Officer (OOS) -->
        <mxCell id="actor_finance" parent="1" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;fontSize=9;fontStyle=1;fillColor=#f5f5f5;strokeColor=#999999;fontColor=#999999;" value="Finance Officer&#xa;(OUT OF SCOPE)" vertex="1">
          <mxGeometry x="120" y="660" width="30" height="55" as="geometry"/>
        </mxCell>

        <!-- ═══ ACTOR → USE CASE ASSOCIATIONS ═══ -->
        <!-- Student → UC1 -->
        <mxCell id="a_stu_uc1" parent="1" style="endArrow=none;strokeColor=#333333;strokeWidth=1;" edge="1" source="actor_student" target="uc1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Student → UC2 (view attendance) -->
        <mxCell id="a_stu_uc9" parent="1" style="endArrow=none;strokeColor=#333333;strokeWidth=1;" edge="1" source="actor_student" target="uc_transcript">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Student → placeholder assignments -->
        <mxCell id="a_stu_assign" parent="1" style="endArrow=none;strokeColor=#999999;strokeWidth=1;dashed=1;dashPattern=8 4;" edge="1" source="actor_student" target="uc_assign">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Student → placeholder exam -->
        <mxCell id="a_stu_exam" parent="1" style="endArrow=none;strokeColor=#999999;strokeWidth=1;dashed=1;dashPattern=8 4;" edge="1" source="actor_student" target="uc_exam">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Faculty → UC2 -->
        <mxCell id="a_fac_uc2" parent="1" style="endArrow=none;strokeColor=#333333;strokeWidth=1;" edge="1" source="actor_faculty" target="uc2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Faculty → UC3 -->
        <mxCell id="a_fac_uc3" parent="1" style="endArrow=none;strokeColor=#333333;strokeWidth=1;" edge="1" source="actor_faculty" target="uc3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Advisor → UC1 (approve/reject) -->
        <mxCell id="a_adv_uc1" parent="1" style="endArrow=none;strokeColor=#333333;strokeWidth=1;" edge="1" source="actor_advisor" target="uc1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Administrator → UC4 -->
        <mxCell id="a_adm_uc4" parent="1" style="endArrow=none;strokeColor=#333333;strokeWidth=1;" edge="1" source="actor_admin" target="uc4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Administrator → UC10 (reports) -->
        <mxCell id="a_adm_uc10" parent="1" style="endArrow=none;strokeColor=#333333;strokeWidth=1;" edge="1" source="actor_admin" target="uc_reports">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- System → UC5 -->
        <mxCell id="a_sys_uc5" parent="1" style="endArrow=none;strokeColor=#9673a6;strokeWidth=1;" edge="1" source="actor_system" target="uc5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- System → UC6 -->
        <mxCell id="a_sys_uc6" parent="1" style="endArrow=none;strokeColor=#9673a6;strokeWidth=1;" edge="1" source="actor_system" target="uc6">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- System → UC7 -->
        <mxCell id="a_sys_uc7" parent="1" style="endArrow=none;strokeColor=#9673a6;strokeWidth=1;" edge="1" source="actor_system" target="uc7">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- System → UC8 -->
        <mxCell id="a_sys_uc8" parent="1" style="endArrow=none;strokeColor=#9673a6;strokeWidth=1;" edge="1" source="actor_system" target="uc8">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Finance Officer → Fee Vouchers (grey) -->
        <mxCell id="a_fin_fee" parent="1" style="endArrow=none;strokeColor=#999999;strokeWidth=1;dashed=1;dashPattern=8 4;" edge="1" source="actor_finance" target="uc_fee">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ═══ INCLUDE RELATIONSHIPS ═══ -->
        <!-- UC1 includes Login -->
        <mxCell id="inc_note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fontSize=9;align=left;spacingLeft=8;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;b&gt;«include» Authentication&lt;/b&gt;&#xa;All use cases require login.&#xa;Shown as note per convention&#xa;(avoids spider-web arrows)." vertex="1">
          <mxGeometry x="1080" y="400" width="210" height="70" as="geometry"/>
        </mxCell>

        <!-- ═══ 4+1 CROSS-REFERENCE NOTE ═══ -->
        <mxCell id="cross_note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=18;fontSize=9;align=left;spacingLeft=10;spacingTop=4;fillColor=#FFFFFF;strokeColor=#333333;" value="&lt;b&gt;4+1 Cross-Reference&lt;/b&gt;&lt;br&gt;&lt;hr&gt;UC1 drives: Logical (AcademicSubsystem),&#xa;  Process (Enrollment Transaction),&#xa;  Development (EnrollmentController)&lt;br&gt;UC3 drives: Logical (GradingSubsystem),&#xa;  Process (DB Trigger Engine),&#xa;  Development (GradeController)&lt;br&gt;UC5–UC8 drive: Process (Scheduler)&lt;br&gt;All UCs drive: Physical (3-tier topology)" vertex="1">
          <mxGeometry x="1080" y="510" width="260" height="170" as="geometry"/>
        </mxCell>

        <!-- ═══ LEGEND ═══ -->
        <mxCell id="legend" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=18;fontSize=10;align=left;spacingLeft=10;spacingTop=4;fillColor=#FFFFFF;strokeColor=#333333;" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;&lt;hr&gt;Solid ellipse = in-scope use case&lt;br&gt;Dashed grey ellipse = placeholder / OOS&lt;br&gt;Colored actor = active in v1.0&lt;br&gt;Grey actor = out of scope (v2.0)" vertex="1">
          <mxGeometry x="1080" y="80" width="260" height="100" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
