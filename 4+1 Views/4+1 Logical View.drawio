        <!-- ═══ ATTENDANCE SUBSYSTEM ═══ -->
        <mxCell id="attend_pkg" parent="1" style="shape=folder;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;spacingTop=10;fontSize=11;fontStyle=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;tabWidth=130;tabHeight=20;tabPosition=left;" value="«subsystem»&#xa;AttendanceSubsystem" vertex="1">
