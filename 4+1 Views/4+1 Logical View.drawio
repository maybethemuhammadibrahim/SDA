          <mxGeometry x="15" y="45" width="190" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="user_attrs" parent="user_cls" style="text;html=1;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" value="user_id : INT «PK»&#xa;username : VARCHAR&#xa;password : VARCHAR (bcrypt)&#xa;role : ENUM&#xa;is_active : BOOLEAN" vertex="1">
          <mxGeometry y="26" width="190" height="94" as="geometry"/>
        </mxCell>

