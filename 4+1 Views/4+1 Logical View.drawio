<mxfile host="app.diagrams.net" agent="draw.io">
  <diagram id="logical-view" name="4+1 Logical View">
    <mxGraphModel dx="1800" dy="1050" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- TITLE -->
        <mxCell id="title" parent="1" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fontFamily=Helvetica;fontColor=#1a1a2e;" value="Smart Campus Hub — 4+1 Logical View" vertex="1">
          <mxGeometry x="400" y="10" width="500" height="30" as="geometry"/>
        </mxCell>

        <!-- ═══ AUTH SUBSYSTEM ═══ -->
        <mxCell id="auth_pkg" parent="1" style="shape=folder;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;spacingTop=10;fontSize=11;fontStyle=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;tabWidth=120;tabHeight=20;tabPosition=left;" value="«subsystem»&#xa;AuthSubsystem" vertex="1">
          <mxGeometry x="30" y="80" width="220" height="180" as="geometry"/>
