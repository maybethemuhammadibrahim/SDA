<mxfile host="app.diagrams.net" agent="draw.io">
  <diagram id="process-view" name="4+1 Process View">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- TITLE -->
        <mxCell id="title" parent="1" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fontFamily=Helvetica;fontColor=#1a1a2e;" value="Smart Campus Hub — 4+1 Process View (Runtime Processes &amp; Concurrency)" vertex="1">
          <mxGeometry x="300" y="10" width="650" height="30" as="geometry"/>
        </mxCell>

        <!-- ═══ BROWSER PROCESS ═══ -->
        <mxCell id="browser_proc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;spacingTop=5;fontSize=11;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;arcSize=8;" value="«process» Browser Session (per user)" vertex="1">
          <mxGeometry x="30" y="80" width="240" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="bp_note" parent="browser_proc" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fontSize=9;align=left;spacingLeft=8;fillColor=#FFFFFF;strokeColor=#6c8ebf;" value="• Renders HTML Views&#xa;• Sends HTTPS requests&#xa;• Receives JSON/HTML responses&#xa;• One session per authenticated user" vertex="1">
          <mxGeometry x="10" y="35" width="220" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="bp_actors" parent="browser_proc" style="text;html=1;fontSize=9;fontColor=#6c8ebf;align=left;" value="Actors: Student, Faculty, Advisor, Admin" vertex="1">
          <mxGeometry x="10" y="115" width="220" height="20" as="geometry"/>
        </mxCell>

        <!-- ═══ HTTP REQUEST HANDLER ═══ -->
        <mxCell id="http_proc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;spacingTop=5;fontSize=11;fontStyle=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;arcSize=8;" value="«process» HTTP Request Handler (multi-threaded)" vertex="1">
          <mxGeometry x="380" y="80" width="340" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="http_note" parent="http_proc" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fontSize=9;align=left;spacingLeft=8;fillColor=#FFFFFF;strokeColor=#82b366;" value="• Routes requests to Controllers&#xa;• AuthController validates session/RBAC&#xa;• EnrollmentController (transactional)&#xa;• GradeController, AttendanceController&#xa;• AdminController, AuditController&#xa;• Returns response to browser" vertex="1">
          <mxGeometry x="10" y="35" width="320" height="110" as="geometry"/>
        </mxCell>

        <!-- ═══ AUTH / SESSION PROCESS ═══ -->
        <mxCell id="auth_proc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fontStyle=1;verticalAlign=middle;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;arcSize=8;" value="«process»&#xa;Auth Session Manager&#xa;(bcrypt validation, RBAC check)" vertex="1">
          <mxGeometry x="380" y="290" width="340" height="70" as="geometry"/>
        </mxCell>

        <!-- ═══ ENROLLMENT TRANSACTION ═══ -->
        <mxCell id="enroll_proc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;spacingTop=5;fontSize=11;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;arcSize=8;" value="«process» Enrollment Transaction (NFR-05)" vertex="1">
          <mxGeometry x="380" y="410" width="340" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="enroll_note" parent="enroll_proc" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fontSize=9;align=left;spacingLeft=8;fillColor=#FFFFFF;strokeColor=#d6b656;" value="• BEGIN TRANSACTION&#xa;• Check capacity (SELECT FOR UPDATE)&#xa;• Check prerequisites&#xa;• INSERT enrollment row&#xa;• COMMIT or ROLLBACK&#xa;• Concurrent-safe: no race conditions" vertex="1">
          <mxGeometry x="10" y="35" width="320" height="85" as="geometry"/>
        </mxCell>

        <!-- ═══ SCHEDULER / CRON ═══ -->
        <mxCell id="sched_proc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;spacingTop=5;fontSize=11;fontStyle=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;arcSize=8;" value="«process» Scheduler / Cron Job Runner (System Timer)" vertex="1">
          <mxGeometry x="830" y="80" width="350" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="sched_fr23" parent="sched_proc" style="html=1;whiteSpace=wrap;fontSize=9;fontStyle=1;verticalAlign=middle;fillColor=#FFFFFF;strokeColor=#9673a6;strokeWidth=1;" value="FR-23: Auto-lock Registration" vertex="1">
          <mxGeometry x="10" y="40" width="200" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="sched_fr24" parent="sched_proc" style="html=1;whiteSpace=wrap;fontSize=9;fontStyle=1;verticalAlign=middle;fillColor=#FFFFFF;strokeColor=#9673a6;strokeWidth=1;" value="FR-24: Low-Attendance Alerts" vertex="1">
          <mxGeometry x="10" y="80" width="200" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="sched_fr25" parent="sched_proc" style="html=1;whiteSpace=wrap;fontSize=9;fontStyle=1;verticalAlign=middle;fillColor=#FFFFFF;strokeColor=#9673a6;strokeWidth=1;" value="FR-25: Batch CGPA Compute" vertex="1">
          <mxGeometry x="10" y="120" width="200" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="sched_fr26" parent="sched_proc" style="html=1;whiteSpace=wrap;fontSize=9;fontStyle=1;verticalAlign=middle;fillColor=#FFFFFF;strokeColor=#9673a6;strokeWidth=1;" value="FR-26: Daily Database Backup" vertex="1">
          <mxGeometry x="10" y="160" width="200" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="sched_timing" parent="sched_proc" style="text;html=1;fontSize=8;fontColor=#9673a6;align=left;" value="Runs asynchronously at configured times" vertex="1">
          <mxGeometry x="220" y="40" width="120" height="50" as="geometry"/>
        </mxCell>

        <!-- ═══ DB TRIGGER ENGINE ═══ -->
        <mxCell id="trigger_proc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;spacingTop=5;fontSize=11;fontStyle=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;arcSize=8;" value="«process» DB Trigger Engine (MySQL internal)" vertex="1">
          <mxGeometry x="830" y="350" width="350" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="trig_note" parent="trigger_proc" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fontSize=9;align=left;spacingLeft=8;fillColor=#FFFFFF;strokeColor=#b85450;" value="• AFTER INSERT/UPDATE/DELETE on grades → audit_log&#xa;• AFTER INSERT/UPDATE on attendance → audit_log&#xa;• BEFORE INSERT on attendance → reject future dates&#xa;• Zero application-side responsibility (NFR-06)" vertex="1">
          <mxGeometry x="10" y="35" width="330" height="80" as="geometry"/>
        </mxCell>

        <!-- ═══ NOTIFICATION DISPATCHER ═══ -->
        <mxCell id="notif_proc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fontStyle=1;verticalAlign=middle;fillColor=#FFFFFF;strokeColor=#7B68A2;strokeWidth=1;dashed=1;dashPattern=8 8;arcSize=8;" value="«process» [optional]&#xa;Notification Dispatcher&#xa;(SMTP / API — email alerts)" vertex="1">
          <mxGeometry x="830" y="530" width="350" height="70" as="geometry"/>
        </mxCell>

        <!-- ═══ FINANCE PROCESS (OOS) ═══ -->
        <mxCell id="fin_proc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fontStyle=1;verticalAlign=middle;fillColor=#f5f5f5;strokeColor=#999999;strokeWidth=1;dashed=1;dashPattern=8 8;fontColor=#999999;arcSize=8;" value="«process» FinanceModule&#xa;(OUT OF SCOPE — v2.0)" vertex="1">
          <mxGeometry x="830" y="640" width="350" height="50" as="geometry"/>
        </mxCell>

        <!-- ═══ CONNECTORS ═══ -->
        <!-- Browser → HTTP Handler -->
        <mxCell id="e_br_http" parent="1" style="endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=2;" edge="1" source="browser_proc" target="http_proc">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_br_http_l" parent="e_br_http" style="edgeLabel;html=1;fontSize=10;fontStyle=1;fontColor=#333333;fillColor=#FFFFFF;" value="«HTTPS»&#xa;synchronous" vertex="1" connectable="0">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>
        <!-- HTTP → Auth Session -->
        <mxCell id="e_http_auth" parent="1" style="endArrow=open;endFill=0;strokeColor=#82b366;strokeWidth=1;dashed=1;dashPattern=8 4;" edge="1" source="http_proc" target="auth_proc">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_http_auth_l" parent="e_http_auth" style="edgeLabel;html=1;fontSize=9;fontColor=#82b366;fillColor=#FFFFFF;" value="«validates»" vertex="1" connectable="0">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>
        <!-- HTTP → Enrollment Transaction -->
        <mxCell id="e_http_enroll" parent="1" style="endArrow=open;endFill=0;strokeColor=#d6b656;strokeWidth=1;dashed=1;dashPattern=8 4;" edge="1" source="http_proc" target="enroll_proc">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_http_enroll_l" parent="e_http_enroll" style="edgeLabel;html=1;fontSize=9;fontColor=#d6b656;fillColor=#FFFFFF;" value="«invokes»&#xa;(transactional)" vertex="1" connectable="0">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>
        <!-- HTTP → DB Triggers -->
        <mxCell id="e_http_trig" parent="1" style="endArrow=open;endFill=0;strokeColor=#b85450;strokeWidth=1;dashed=1;dashPattern=8 4;" edge="1" source="http_proc" target="trigger_proc">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_http_trig_l" parent="e_http_trig" style="edgeLabel;html=1;fontSize=9;fontColor=#b85450;fillColor=#FFFFFF;" value="«triggers»&#xa;(implicit on DML)" vertex="1" connectable="0">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>
        <!-- Scheduler → DB Triggers -->
        <mxCell id="e_sched_trig" parent="1" style="endArrow=open;endFill=0;strokeColor=#9673a6;strokeWidth=1;dashed=1;dashPattern=8 4;" edge="1" source="sched_proc" target="trigger_proc">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_sched_trig_l" parent="e_sched_trig" style="edgeLabel;html=1;fontSize=9;fontColor=#9673a6;fillColor=#FFFFFF;" value="«schedules»" vertex="1" connectable="0">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>
        <!-- Scheduler → Notification -->
        <mxCell id="e_sched_notif" parent="1" style="endArrow=open;endFill=0;strokeColor=#7B68A2;strokeWidth=1;dashed=1;dashPattern=8 4;" edge="1" source="sched_proc" target="notif_proc">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_sched_notif_l" parent="e_sched_notif" style="edgeLabel;html=1;fontSize=9;fontColor=#7B68A2;fillColor=#FFFFFF;" value="«SMTP / API»&#xa;FR-24 alerts" vertex="1" connectable="0">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>
        <!-- Finance (OOS) -->
        <mxCell id="e_fin" parent="1" style="endArrow=open;endFill=0;strokeColor=#999999;strokeWidth=1;dashed=1;dashPattern=8 4;" edge="1" source="http_proc" target="fin_proc">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_fin_l" parent="e_fin" style="edgeLabel;html=1;fontSize=9;fontColor=#999999;fillColor=#FFFFFF;" value="Future (v2.0)" vertex="1" connectable="0">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>

        <!-- ═══ LEGEND ═══ -->
        <mxCell id="legend" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=18;fontSize=10;align=left;spacingLeft=10;spacingTop=4;fillColor=#FFFFFF;strokeColor=#333333;" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;&lt;hr&gt;Solid arrow = synchronous call&lt;br&gt;Dashed arrow = async / implicit&lt;br&gt;Purple dashed = optional service&lt;br&gt;Grey dashed = out of scope (v2.0)" vertex="1">
          <mxGeometry x="30" y="590" width="240" height="100" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
